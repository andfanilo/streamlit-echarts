{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(uv sync *)",
      "Bash(uv build *)",
      "Bash(uv run python *)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run streamlit *)",
      "Bash(uv run pre-commit *)",
      "Bash(npm *)",
      "Bash(npx tsc *)",
      "Bash(npx prettier *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh run watch *)",
      "Bash(gh workflow view *)",
      "Bash(gh workflow list *)",
      "Bash(gh search *)"
    ],
    "ask": [
      "Bash(gh pr create *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop_check.sh",
            "timeout": 120,
            "statusMessage": "Running checks (fast)..."
          }
        ]
      }
    ]
  }
}